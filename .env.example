ZOTERO_API_KEY=your_zotero_api_key

# Optional. If omitted for a user library, the server resolves the user ID
# automatically from the API key via /keys/<key>.
ZOTERO_LIBRARY_TYPE=user              # set to "group" when targeting a Zotero group library
ZOTERO_LIBRARY_ID=                     # numeric group ID (found in https://www.zotero.org/groups/<ID>/...) when using ZOTERO_LIBRARY_TYPE=group

# Optional overrides
ZOTERO_API_BASE_URL=https://api.zotero.org
ZOTERO_API_VERSION=3
ZOTERO_DEFAULT_LIMIT=25
LOG_LEVEL=WARNING
